# Назва проєкта (ідентифікатор для ізоляції даних)
VITE_PROJECT_ID=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App Check (reCAPTCHA v3). Публічний site key з Firebase Console → App Check → Apps.
# Обов'язковий для продакшену (захист від скриптів). Додайте також у GitHub Actions Secrets.
VITE_APPCHECK_RECAPTCHA_SITE_KEY=
# Лише для локальної розробки: debug-токен з консолі (App Check → ⋮ → Manage debug tokens).
# У продакшен НЕ додавати.
VITE_APPCHECK_DEBUG_TOKEN=
