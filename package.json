		"@vitest/coverage-v8": "^3.2.4",
		"gray-matter": "^4.0.3",
		"jsdom": "^26.1.0",
		"lucide-svelte": "^1.0.1",
		"marked": "^17.0.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
