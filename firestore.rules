rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == "superadmin";
    }

    function belongsToProject(projectId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             projectId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects;
    }

    function hasPerm(projectId, action) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && (
          (action == 'create' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].permissions.canCreate == true) ||
          (action == 'edit' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].permissions.canEdit == true) ||
          (action == 'delete' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].permissions.canDelete == true)
        )
      );
    }

    function isProjectAdmin(projectId) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == "admin"
      );
    }

    // Допоміжна функція для перевірки ієрархії ролей при керуванні користувачами
    function canManageTarget(projectId, targetRole) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].permissions.canManageUsers == true && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'admin' && (targetRole == 'moderator' || targetRole == 'assistant')) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'moderator' && targetRole == 'assistant')
      );
    }

    // 3-B: Жорсткі ліміти на розмір даних (Payload Size) та структуру документа
    function isValidArticle(data) {
      return data.keys().hasOnly(['title', 'content', 'category', 'lang', 'author', 'isPublished', 'createdAt', 'updatedAt', 'translations', 'dateMode', 'customDate']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.content is string && data.content.size() <= 50000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 32 &&
             data.lang in ['uk', 'en'] &&
             data.author is string && data.author.size() <= 100 &&
             data.isPublished is bool &&
             (!('dateMode' in data) || data.dateMode is string) &&
             (!('customDate' in data) || data.customDate == null || data.customDate is timestamp) &&
             (!('translations' in data) || data.translations is map);
    }

    function isValidProjectUpdate(data) {
      return data.keys().hasAny(['name', 'region']) &&
             data.keys().hasOnly(['name', 'region']) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('region' in data) || (data.region is string && data.region.size() <= 50));
    }

    match /projects/{projectId}/articles/{articleId} {
      allow read: if resource.data.isPublished == true || (isSignedIn() && (isSuperAdmin() || belongsToProject(projectId)));
      allow create: if hasPerm(projectId, 'create') && isValidArticle(request.resource.data);
      allow update: if hasPerm(projectId, 'edit') 
                    && isValidArticle(request.resource.data)
                    && request.time > resource.data.updatedAt + duration.value(20, 's');
      allow delete: if hasPerm(projectId, 'delete');
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isProjectAdmin(projectId) && 
                      (request.method == 'delete' || isValidProjectUpdate(request.resource.data));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isSuperAdmin() || (
        isSignedIn() && (
          (request.auth.uid == userId && exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()))) ||
          (
            'lastModifiedProject' in request.resource.data &&
            canManageTarget(request.resource.data.lastModifiedProject, request.resource.data.projects[request.resource.data.lastModifiedProject].role)
          )
        )
      );

      allow delete: if isSuperAdmin() || (
        isSignedIn() && request.auth.token.email.lower() == userId.lower()
      );

      allow update: if isSuperAdmin() || (
        isSignedIn() && (
          (request.auth.uid == userId && 
           request.resource.data.isSuperAdmin == resource.data.isSuperAdmin &&
           request.resource.data.projects == resource.data.projects) ||
          (
            request.resource.data.isSuperAdmin == resource.data.isSuperAdmin &&
            'lastModifiedProject' in request.resource.data &&
            canManageTarget(request.resource.data.lastModifiedProject, request.resource.data.projects[request.resource.data.lastModifiedProject].role) &&
            request.resource.data.projects.diff(resource.data.projects).affectedKeys().hasOnly([request.resource.data.lastModifiedProject])
          )
        )
      );
    }
  }
}
