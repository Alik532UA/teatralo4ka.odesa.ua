rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "superadmin" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true)
      );
    }

    function belongsToProject(projectId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             projectId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects;
    }

    function getProjectPerms(projectId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].permissions;
    }

    function hasArticlePerm(projectId, action) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && (
          (action == 'create' && getProjectPerms(projectId).get('canCreateArticles', getProjectPerms(projectId).get('canCreate', false)) == true) ||
          (action == 'edit' && getProjectPerms(projectId).get('canEditArticles', getProjectPerms(projectId).get('canEdit', false)) == true) ||
          (action == 'delete' && getProjectPerms(projectId).get('canDeleteArticles', getProjectPerms(projectId).get('canDelete', false)) == true)
        )
      );
    }

    function hasPagePerm(projectId, action) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && (
          (action == 'create' && getProjectPerms(projectId).get('canCreatePages', getProjectPerms(projectId).get('canCreate', false)) == true) ||
          (action == 'edit' && getProjectPerms(projectId).get('canEditPages', getProjectPerms(projectId).get('canEdit', false)) == true) ||
          (action == 'delete' && getProjectPerms(projectId).get('canDeletePages', getProjectPerms(projectId).get('canDelete', false)) == true)
        )
      );
    }

    function canManageSettings(projectId) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && 
        getProjectPerms(projectId).get('canManageSettings', get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'admin') == true
      );
    }

    function isProjectAdmin(projectId) {
      return isSuperAdmin() || (
        belongsToProject(projectId) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == "admin"
      );
    }

    function canManageTarget(projectId, targetRole) {
      return belongsToProject(projectId) && 
             getProjectPerms(projectId).get('canManageUsers', get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'admin') == true && (
               (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'admin' && (targetRole == 'moderator' || targetRole == 'assistant')) ||
               (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects[projectId].role == 'moderator' && targetRole == 'assistant')
             );
    }

    // FIX B1: Розширена валідація translation block — додано isPublished, coverUrl, contentFormat, excerpt, externalUrl
    function isValidTranslationBlock(block) {
      return block.keys().hasOnly(['title', 'content', 'isPublished', 'coverUrl', 'contentFormat', 'excerpt', 'externalUrl']) &&
             (!('title' in block) || (block.title is string && block.title.size() <= 150)) &&
             (!('content' in block) || (block.content is string && block.content.size() <= 50000)) &&
             (!('isPublished' in block) || block.isPublished is bool) &&
             (!('coverUrl' in block) || (block.coverUrl is string && block.coverUrl.size() <= 2048)) &&
             (!('contentFormat' in block) || block.contentFormat in ['markdown', 'html']) &&
             (!('excerpt' in block) || (block.excerpt is string && block.excerpt.size() <= 500)) &&
             (!('externalUrl' in block) || (block.externalUrl is string && block.externalUrl.size() <= 2048));
    }

    function isValidTranslations(translations) {
      return translations.keys().hasOnly(['en', 'uk']) &&
             (!('en' in translations) || isValidTranslationBlock(translations.en)) &&
             (!('uk' in translations) || isValidTranslationBlock(translations.uk));
    }

    // FIX S3, S4, S5, S10, S11: Повна валідація статті (+ sortOrder)
    function isValidArticle(data) {
      return data.keys().hasOnly(['title', 'content', 'category', 'lang', 'author', 'isPublished', 'createdAt', 'updatedAt', 'translations', 'dateMode', 'customDate', 'coverUrl', 'slug', 'type', 'sortOrder']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.content is string && data.content.size() <= 50000 &&
             data.category is string && data.category.size() <= 50 &&
             data.lang in ['uk', 'en'] &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             data.isPublished is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() <= 2048)) &&
             (!('dateMode' in data) || (data.dateMode is string && data.dateMode.size() <= 20)) &&
             (!('customDate' in data) || data.customDate == null || 
               (data.customDate is timestamp && 
                data.customDate > timestamp.date(1990, 1, 1) && 
                data.customDate < request.time + duration.value(365, 'd'))) &&
             (!('slug' in data) || (data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100 && data.slug.matches('[a-z0-9_]+'))) &&
             (!('type' in data) || data.type in ['article', 'page', 'page_project']) &&
             (!('sortOrder' in data) || (data.sortOrder is int && data.sortOrder >= 0 && data.sortOrder <= 9999)) &&
             (!('translations' in data) || isValidTranslations(data.translations));
    }

    function isValidProjectUpdate(data) {
      return data.keys().hasAny(['name', 'region']) &&
             data.keys().hasOnly(['name', 'region']) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('region' in data) || (data.region is string && data.region.size() <= 50));
    }

    match /projects/{projectId}/articles/{articleId} {
      allow read: if resource.data.isPublished == true || (isSignedIn() && (isSuperAdmin() || belongsToProject(projectId)));
      
      allow create: if (request.resource.data.get('type', 'article') == 'article' ? hasArticlePerm(projectId, 'create') : hasPagePerm(projectId, 'create')) 
                    && isValidArticle(request.resource.data)
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.updatedAt == request.time;
      
      allow update: if (resource.data.get('type', 'article') == 'article' ? hasArticlePerm(projectId, 'edit') : hasPagePerm(projectId, 'edit')) 
                    && isValidArticle(request.resource.data)
                    && request.resource.data.updatedAt == request.time
                    && request.time > resource.data.updatedAt + duration.value(1, 's');
      
      allow delete: if (resource.data.get('type', 'article') == 'article' ? hasArticlePerm(projectId, 'delete') : hasPagePerm(projectId, 'delete'));
    }

    match /projects/{projectId}/settings/{settingId} {
      // 'home', 'header', 'news', 'projects', 'about' are publicly readable so the site can render without auth.
      allow read: if settingId in ['home', 'header', 'news', 'projects', 'about'] || (isSignedIn() && (isSuperAdmin() || belongsToProject(projectId)));
      allow write: if canManageSettings(projectId);
    }

    match /projects/{projectId} {
      // ЗАХИСТ: Метадані проєкту доступні лише учасникам (запобігає перерахуванню всіх проєктів).
      allow read: if isSignedIn() && (isSuperAdmin() || belongsToProject(projectId));
      // ЗАХИСТ: Звичайні адміни більше не можуть видалити школу цілком (Тільки Суперадмін).
      // Адміни можуть тільки оновлювати поля (наприклад, назву, регіон).
      allow write: if (isSuperAdmin() && request.method == 'delete') || 
                      (isProjectAdmin(projectId) && request.method != 'delete' && isValidProjectUpdate(request.resource.data));
    }

    match /users/{userId} {
      allow get: if isSuperAdmin() || (
        isSignedIn() && (
          request.auth.uid == userId ||
          resource.data.projects.keys().hasAny(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projects.keys())
        )
      );
      
      // FIX S1: Per-document перевірка спільних проєктів.
      allow list: if isSuperAdmin() || (
        isSignedIn() && 
        resource.data.projectIds.hasAny(
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.projectIds
        )
      );
      
      allow create: if isSuperAdmin() || (
        isSignedIn() && (
          // СЦЕНАРІЙ А: Міграція профілю (Email -> UID) при першому вході
          (
            request.auth.uid == userId && 
            request.auth.token.email_verified == true &&
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
            request.resource.data.diff(get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data).affectedKeys().hasOnly(['projectIds']) &&
            request.resource.data.projectIds.hasOnly(request.resource.data.projects.keys()) &&
            request.resource.data.projects.keys().hasOnly(request.resource.data.projectIds)
          ) ||
          // СЦЕНАРІЙ Б: Адмін школи створює нового користувача (додає його по Email)
          (
            userId.matches('.*@.*[.].*') &&
            request.resource.data.keys().hasOnly(['email', 'isSuperAdmin', 'projects', 'projectIds', 'lastModifiedProject', 'createdAt', '_createdByUid']) &&
            request.resource.data._createdByUid == request.auth.uid &&
            request.resource.data.email is string &&
            'lastModifiedProject' in request.resource.data &&
            request.resource.data.isSuperAdmin == false &&
            request.resource.data.projects.keys().hasOnly([request.resource.data.lastModifiedProject]) &&
            request.resource.data.projectIds.hasOnly([request.resource.data.lastModifiedProject]) &&
            canManageTarget(request.resource.data.lastModifiedProject, request.resource.data.projects[request.resource.data.lastModifiedProject].role)
          )
        )
      );

      allow delete: if isSuperAdmin() || (
        isSignedIn() && (
          request.auth.uid == userId ||
          request.auth.token.email.lower() == userId
        )
      );

      allow update: if isSuperAdmin() || (
        isSignedIn() && (
          // СЦЕНАРІЙ 1: Користувач оновлює сам себе (обмежено поля)
          (request.auth.uid == userId && 
           request.resource.data.keys().hasOnly(['email', 'name', 'projects', 'projectIds', 'isSuperAdmin', 'lastModifiedProject', 'createdAt', 'updatedAt', 'avatar', 'phone', '_createdByUid']) &&
           request.resource.data.isSuperAdmin == resource.data.isSuperAdmin &&
           request.resource.data.projects == resource.data.projects &&
           request.resource.data.projectIds == resource.data.projectIds &&
           request.resource.data.createdAt == resource.data.createdAt &&
           (!('_createdByUid' in resource.data) || request.resource.data._createdByUid == resource.data._createdByUid)) ||
          
          // СЦЕНАРІЙ 2: Адмін/модератор керує користувачем
          (
            request.resource.data.isSuperAdmin == resource.data.isSuperAdmin &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['projects', 'projectIds', 'lastModifiedProject']) &&
            'lastModifiedProject' in request.resource.data &&
            request.resource.data.projects.diff(resource.data.projects).affectedKeys().hasOnly([request.resource.data.lastModifiedProject]) &&
            request.resource.data.projectIds.hasOnly(request.resource.data.projects.keys()) &&
            request.resource.data.projects.keys().hasOnly(request.resource.data.projectIds) &&
            resource.data.projects.keys().hasOnly([request.resource.data.lastModifiedProject]) &&
            (
              (request.resource.data.lastModifiedProject in request.resource.data.projects &&
               canManageTarget(request.resource.data.lastModifiedProject, request.resource.data.projects[request.resource.data.lastModifiedProject].role)) ||
              (!(request.resource.data.lastModifiedProject in request.resource.data.projects) &&
               request.resource.data.lastModifiedProject in resource.data.projects &&
               canManageTarget(request.resource.data.lastModifiedProject, resource.data.projects[request.resource.data.lastModifiedProject].role))
            )
          )
        )
      );
    }
  }
}